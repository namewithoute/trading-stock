{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "🚀 Launch API Server",
            "type": "go",
            "request": "launch",
            "mode": "debug",
            "program": "${workspaceFolder}/cmd/api/main.go",
            "env": {
                "APP_ENV": "dev"
            },
            "cwd": "${workspaceFolder}",
            "showLog": true
        },
        {
            "name": "🧪 Debug Current Test",
            "type": "go",
            "request": "launch",
            "mode": "test",
            "program": "${fileDirname}",
            "env": {
                "APP_ENV": "test"
            },
            "cwd": "${workspaceFolder}",
            "showLog": true
        },
        {
            "name": "📂 Debug Current Package",
            "type": "go",
            "request": "launch",
            "mode": "auto",
            "program": "${fileDirname}",
            "cwd": "${workspaceFolder}"
        }
    ]
}