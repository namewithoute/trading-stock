    {
      "name": "üîß Quick Flow ‚Äî E2E Test",
      "description": "Run these requests in order to execute a full trading flow end-to-end:\n\n1. Register ‚Üí 2. Login ‚Üí 3. Create Account ‚Üí 4. Deposit ‚Üí 5. Create BUY Order ‚Üí 6. Create SELL Order ‚Üí 7. List Trades",
      "item": [
        {
          "name": "1. Register",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"e2e_test@example.com\",\n  \"password\": \"Test1234!\",\n  \"name\": \"E2E Tester\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/auth/register",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "auth", "register"]
            }
          }
        },
        {
          "name": "2. Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var res = pm.response.json();",
                  "if (res.data) {",
                  "  pm.collectionVariables.set('access_token',  res.data.access_token);",
                  "  pm.collectionVariables.set('refresh_token', res.data.refresh_token);",
                  "  pm.collectionVariables.set('user_id',       res.data.user_id);",
                  "  console.log('Tokens saved.');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"e2e_test@example.com\",\n  \"password\": \"Test1234!\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/auth/login",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "auth", "login"]
            }
          }
        },
        {
          "name": "3. Create Cash Account",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var res = pm.response.json();",
                  "if (res.data && res.data.id) {",
                  "  pm.collectionVariables.set('account_id', res.data.id);",
                  "  console.log('Account ID saved:', res.data.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"account_type\": \"cash\",\n  \"currency\": \"VND\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/accounts",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "accounts"]
            }
          }
        },
        {
          "name": "4. Deposit 50,000,000 VND",
